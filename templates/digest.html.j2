<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sift — {{ date_label }}</title>
<style>
  :root {
    --bg: #ffffff;
    --surface: #f5f5f7;
    --border: #d1d1d6;
    --text: #1d1d1f;
    --secondary: #6e6e73;
    --accent: #0071e3;
    --read-opacity: 0.45;
    --cluster-bg: #f0f4ff;
    --cluster-border: #c7d2fe;
    --divider: #e5e5ea;
    --button-bg: #e9e9eb;
    --button-hover: #d1d1d6;
    --saved-bg: #fff7ed;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #1c1c1e;
      --surface: #2c2c2e;
      --border: #3a3a3c;
      --text: #f2f2f7;
      --secondary: #8e8e93;
      --accent: #2997ff;
      --cluster-bg: #1e2340;
      --cluster-border: #3a4080;
      --divider: #3a3a3c;
      --button-bg: #3a3a3c;
      --button-hover: #48484a;
      --saved-bg: #2c2010;
    }
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
    background: var(--bg);
    color: var(--text);
    font-size: 14px;
    line-height: 1.55;
    padding: 24px 32px 48px;
    max-width: 860px;
    margin: 0 auto;
  }

  /* ── Header ─────────────────────────────────────────── */
  .digest-header {
    border-bottom: 2px solid var(--border);
    padding-bottom: 16px;
    margin-bottom: 28px;
  }
  .digest-header h1 {
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.3px;
  }
  .digest-header .meta {
    color: var(--secondary);
    font-size: 13px;
    margin-top: 5px;
  }

  /* ── Cluster section ─────────────────────────────────── */
  .cluster {
    margin-bottom: 36px;
  }
  .cluster-header {
    display: flex;
    align-items: center;
    gap: 10px;
    background: var(--cluster-bg);
    border: 1px solid var(--cluster-border);
    border-radius: 8px;
    padding: 10px 14px;
    margin-bottom: 16px;
  }
  .cluster-icon { font-size: 16px; }
  .cluster-title {
    font-weight: 600;
    font-size: 15px;
    flex: 1;
  }
  .cluster-count {
    font-size: 12px;
    color: var(--secondary);
    background: var(--button-bg);
    border-radius: 99px;
    padding: 2px 8px;
  }

  /* ── Paper card ──────────────────────────────────────── */
  .paper {
    border-bottom: 1px solid var(--divider);
    padding: 14px 0 14px 0;
    transition: opacity 0.25s;
  }
  .paper:last-child { border-bottom: none; }
  .paper.is-read { opacity: var(--read-opacity); }
  .paper.is-saved { background: var(--saved-bg); border-radius: 6px; padding: 14px 10px; }

  .paper-title {
    font-weight: 600;
    font-size: 15px;
    margin-bottom: 3px;
  }
  .paper-meta {
    font-size: 12px;
    color: var(--secondary);
    margin-bottom: 8px;
  }
  .paper-summary {
    font-size: 13.5px;
    line-height: 1.6;
    color: var(--text);
    margin-bottom: 10px;
  }
  .paper-actions {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .paper-link {
    font-size: 12px;
    color: var(--accent);
    text-decoration: none;
  }
  .paper-link:hover { text-decoration: underline; }

  .btn {
    font-size: 11px;
    font-weight: 500;
    padding: 3px 10px;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: var(--button-bg);
    color: var(--text);
    cursor: pointer;
    transition: background 0.15s;
    font-family: inherit;
  }
  .btn:hover { background: var(--button-hover); }
  .btn.read-btn.done {
    color: var(--secondary);
    border-color: var(--border);
    background: var(--button-bg);
    cursor: pointer;
  }
  .btn.save-btn.saved {
    color: var(--accent);
    border-color: var(--accent);
  }

  /* ── BibTeX modal ───────────────────────────────────── */
  .modal-backdrop {
    display: none;
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.45);
    z-index: 100;
    align-items: center;
    justify-content: center;
  }
  .modal-backdrop.open { display: flex; }
  .modal {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 20px;
    width: 540px;
    max-width: 90vw;
    box-shadow: 0 8px 32px rgba(0,0,0,0.25);
  }
  .modal h3 { font-size: 14px; margin-bottom: 10px; }
  .modal textarea {
    width: 100%; height: 160px;
    font-family: "SF Mono", "Fira Mono", monospace;
    font-size: 12px;
    padding: 8px;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--surface);
    color: var(--text);
    resize: none;
  }
  .modal-actions { display: flex; gap: 8px; justify-content: flex-end; margin-top: 10px; }

  /* ── Footer ──────────────────────────────────────────── */
  .digest-footer {
    border-top: 2px solid var(--border);
    padding-top: 14px;
    margin-top: 8px;
    font-size: 12px;
    color: var(--secondary);
  }
</style>
</head>
<body>

<div class="digest-header">
  <h1>📄 Sift — {{ date_label }}</h1>
  <div class="meta">
    {{ total_papers }} paper{{ 's' if total_papers != 1 }} &middot;
    {{ clusters | length }} cluster{{ 's' if clusters | length != 1 }} &middot;
    topics: {{ topics | join(', ') }}
  </div>
</div>

{% for cluster in clusters %}
<div class="cluster">
  <div class="cluster-header">
    <span class="cluster-icon">🗂</span>
    <span class="cluster-title">{{ cluster.label }}</span>
    <span class="cluster-count">{{ cluster.papers | length }} paper{{ 's' if cluster.papers | length != 1 }}</span>
  </div>

  {% for paper in cluster.papers %}
  <div class="paper{% if paper.is_read %} is-read{% endif %}{% if paper.is_saved %} is-saved{% endif %}" id="paper-{{ paper.id | replace('.', '-') }}">
    <div class="paper-title">{{ paper.title }}</div>
    <div class="paper-meta">
      {{ paper.authors[:3] | join(', ') }}{% if paper.authors | length > 3 %} et al.{% endif %}
      &middot; {{ paper.category }} &middot; {{ paper.date_display }}
    </div>
    <div class="paper-summary">{{ paper.summary or paper.abstract[:300] }}</div>
    <div class="paper-actions">
      <a class="paper-link" href="{{ paper.pdf_url }}" target="_blank">→ arxiv.org/abs/{{ paper.id }}</a>
      <button class="btn read-btn{% if paper.is_read %} done{% endif %}"
              onclick="toggleRead('{{ paper.id }}')"
              id="read-btn-{{ paper.id | replace('.', '-') }}">
        {{ '✓ Read' if paper.is_read else 'Mark Read' }}
      </button>
      <button class="btn save-btn{% if paper.is_saved %} saved{% endif %}"
              onclick="toggleSave('{{ paper.id }}')"
              id="save-btn-{{ paper.id | replace('.', '-') }}">
        {{ 'Unsave' if paper.is_saved else 'Save' }}
      </button>
      <button class="btn cite-btn"
              data-id="{{ paper.id }}"
              data-title="{{ paper.title }}"
              data-authors="{{ paper.authors | join(' || ') }}"
              data-year="{{ paper.published_at[:4] }}"
              onclick="copyCitation(this)">
        Copy BibTeX
      </button>
    </div>
  </div>
  {% endfor %}
</div>
{% endfor %}

<div class="digest-footer">
  {{ total_papers }} new &middot;
  {{ read_count }} read &middot;
  generated in {{ generation_time }}
</div>

<script>
  function toggleRead(paperId) {
    const key = paperId.replace(/\./g, '-');
    const card = document.getElementById('paper-' + key);
    const btn  = document.getElementById('read-btn-' + key);
    const reading = card.classList.toggle('is-read');
    btn.textContent = reading ? '✓ Read' : 'Mark Read';
    btn.classList.toggle('done', reading);
    fetch('http://127.0.0.1:{{ action_port }}/' + (reading ? 'mark-read' : 'mark-unread') + '/' + encodeURIComponent(paperId)).catch(() => {});
  }

  function toggleSave(paperId) {
    const key = paperId.replace(/\./g, '-');
    const card = document.getElementById('paper-' + key);
    const btn  = document.getElementById('save-btn-' + key);
    const saving = card.classList.toggle('is-saved');
    btn.textContent = saving ? 'Unsave' : 'Save';
    btn.classList.toggle('saved', saving);
    fetch('http://127.0.0.1:{{ action_port }}/' + (saving ? 'save' : 'unsave') + '/' + encodeURIComponent(paperId)).catch(() => {});
  }

  function copyCitation(btn) {
    const paperId = btn.dataset.id;
    const title   = btn.dataset.title;
    const year    = btn.dataset.year;
    const rawAuthors = (btn.dataset.authors || '').split(' || ').filter(Boolean);
    const authors = rawAuthors.map(function(a) {
      const parts = a.trim().split(' ');
      const last  = parts[parts.length - 1];
      const first = parts.slice(0, -1).join(' ');
      return last + (first ? ', ' + first : '');
    }).join(' and ');
    const key = (rawAuthors[0] ? rawAuthors[0].trim().split(' ').pop().toLowerCase() : 'unknown')
                + year + paperId.replace(/\./g, '');
    const bibtex = '@misc{' + key + ',\n'
      + '  title         = {' + title + '},\n'
      + '  author        = {' + authors + '},\n'
      + '  year          = {' + year + '},\n'
      + '  eprint        = {' + paperId + '},\n'
      + '  archivePrefix = {arXiv},\n'
      + '  url           = {https://arxiv.org/abs/' + paperId + '}\n'
      + '}';
    document.getElementById('bibtex-text').value = bibtex;
    document.getElementById('bibtex-modal').classList.add('open');
    document.getElementById('modal-copy-btn').textContent = 'Copy';
  }

  function copyFromModal() {
    const ta = document.getElementById('bibtex-text');
    ta.select();
    ta.setSelectionRange(0, 99999);
    document.execCommand('copy');
    document.getElementById('modal-copy-btn').textContent = 'Copied!';
  }

  function closeBibtexModal() {
    document.getElementById('bibtex-modal').classList.remove('open');
  }

  document.getElementById('bibtex-modal').addEventListener('click', function(e) {
    if (e.target === this) closeBibtexModal();
  });
</script>
<div class="modal-backdrop" id="bibtex-modal">
  <div class="modal">
    <h3>BibTeX Citation</h3>
    <textarea id="bibtex-text" readonly></textarea>
    <div class="modal-actions">
      <button class="btn" onclick="closeBibtexModal()">Close</button>
      <button class="btn" id="modal-copy-btn" onclick="copyFromModal()">Copy</button>
    </div>
  </div>
</div>

</body>
</html>
